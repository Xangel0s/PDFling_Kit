{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2022", "WebWorker"],
    "types": ["chrome"],
    "outDir": "dist"
  },
  "include": ["src/**/*"]
}